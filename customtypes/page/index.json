{
  "id": "page",
  "label": "Page",
  "format": "page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": ""
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "",
          "allowTargetBlank": true,
          "single": "heading1"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "hero": {
              "type": "SharedSlice"
            },
            "rich_text": {
              "type": "SharedSlice"
            },
            "three_column_features": {
              "type": "SharedSlice"
            },
            "featured_wine": {
              "type": "SharedSlice"
            },
            "domaines_grid": {
              "type": "SharedSlice"
            },
            "members_teaser": {
              "type": "SharedSlice"
            },
            "members_hero": {
              "type": "SharedSlice"
            },
            "how_it_works": {
              "type": "SharedSlice"
            },
            "membership_tiers": {
              "type": "SharedSlice"
            },
            "whats_app_preview": {
              "type": "SharedSlice"
            },
            "application_form": {
              "type": "SharedSlice"
            },
            "origin_story": {
              "type": "SharedSlice"
            },
            "geography": {
              "type": "SharedSlice"
            },
            "domaines_list": {
              "type": "SharedSlice"
            },
            "contact_blocks": {
              "type": "SharedSlice"
            },
            "bottom_contact_cta": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    }
  }
}
